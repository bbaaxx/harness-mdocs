{"timestamp":"2026-06-01T07:55:06.557Z","type":"tool","initiativeId":"add-opencode-mdocs-to-opencode-ecosystem","step":"IDLE","details":{"toolName":"bash","args":{"command":"npx ts-node -e \"\nimport { MdocsLinter } from './src/linter';\nconst linter = new MdocsLinter('./mdocs');\nconst results = linter.lintAll();\nconst graph = results.filter(r => r.file === 'GRAPH');\nconsole.log('Graph results count:', graph.length);\nif (graph.length > 0) {\n  for (const g of graph) {\n    console.log('---');\n    for (const i of g.issues) {\n      console.log(' ', i.severity, ':', i.message);\n    }\n  }\n} else {\n  console.log('No graph warnings — clean!');\n}\n\" 2>&1 | head -50","description":"Re-check graph warnings"}}}
{"timestamp":"2026-06-01T07:55:22.802Z","type":"tool","initiativeId":"add-opencode-mdocs-to-opencode-ecosystem","step":"IDLE","details":{"toolName":"bash","args":{"command":"npx ts-node -e \"\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { parseFrontmatter } from './src/types';\n\nconst baseDir = './mdocs';\nconst warnings: string[] = [];\n\n// Check done initiatives\nconst initiativesDir = path.join(baseDir, 'initiatives');\nconst initFiles = fs.readdirSync(initiativesDir).filter(f => f.endsWith('.md') && f !== 'INDEX.md');\n\n// Collect wiki lifecycle data\nconst wikiDir = path.join(baseDir, 'wiki');\nconst wikiData: any[] = [];\nfor (const cat of fs.readdirSync(wikiDir).filter(f => fs.statSync(path.join(wikiDir, f)).isDirectory())) {\n  for (const f of fs.readdirSync(path.join(wikiDir, cat)).filter(f => f.endsWith('.md') && f !== 'INDEX.md')) {\n    const content = fs.readFileSync(path.join(wikiDir, cat, f), 'utf8');\n    const front = parseFrontmatter(content);\n    wikiData.push({ cat, id: front.id || f.replace('.md',''), lifecycle: front.lifecycle, related_initiatives: front.related_initiatives || [] });\n  }\n}\nconst wikiMap = new Map(wikiData.map(w => [w.cat + '/' + w.id, w]));\nconst stableSet = new Set(wikiData.filter(w => w.lifecycle === 'stable').map(w => w.cat + '/' + w.id));\n\nlet count = 0;\nfor (const f of initFiles) {\n  const content = fs.readFileSync(path.join(initiativesDir, f), 'utf8');\n  const front = parseFrontmatter(content);\n  if (front.status !== 'done') continue;\n  const refs = Array.isArray(front.related_wiki) ? front.related_wiki : [];\n  const hasStable = refs.some((r: string) => stableSet.has(r));\n  if (!hasStable) {\n    console.log('NO STABLE:', front.id, 'refs:', refs);\n    count++;\n  }\n}\nconsole.log('\\\\nDone initiatives without stable wiki learning:', count);\n\n// Check wiki missing backlinks\nconst initData: any[] = [];\nfor (const f of initFiles) {\n  const content = fs.readFileSync(path.join(initiativesDir, f), 'utf8');\n  const front = parseFrontmatter(content);\n  initData.push({ id: front.id, related_wiki: front.related_wiki || [] });\n}\nconst initIds = new Set(initData.map(i => i.id));\nlet backlinkMisses = 0;\nfor (const w of wikiData) {\n  for (const initId of w.related_initiatives) {\n    if (!initIds.has(initId)) {\n      console.log('WIKI BAD INITIATIVE REF:', w.cat + '/' + w.id, '→', initId);\n      backlinkMisses++;\n    }\n  }\n}\nconsole.log('\\\\nWiki → bad initiative refs:', backlinkMisses);\n\n// Check orphan wiki entries (no initiative references them)\nconst referencedWikis = new Set<string>();\nfor (const i of initData) {\n  for (const w of i.related_wiki) {\n    referencedWikis.add(w);\n  }\n}\nlet orphans = 0;\nfor (const w of wikiData) {\n  const slug = w.cat + '/' + w.id;\n  if (!referencedWikis.has(slug)) {\n    console.log('ORPHAN:', slug);\n    orphans++;\n  }\n}\nconsole.log('\\\\nOrphan wiki entries:', orphans);\n\" 2>&1 | head -100","description":"Full audit of all graph warning types"}}}
